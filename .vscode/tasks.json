{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-devhost",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/tapir.DevHost/tapir.DevHost.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "build-tapir",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/tapir.Cli/tapir.Cli.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "dev:watch-devhost",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/src/tapir.DevHost/tapir.DevHost.csproj",
        "--environment",
        "Development",
        "--urls",
        "https://localhost:5001"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src/tapir.DevHost/"
      }
    },
    {
      "label": "test:all-test-cases",
      "command": "dotnet",
      "type": "process",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/src/tapir.Cli/tapir.Cli.csproj",
        "--",
        "run",
        "https://localhost:5001",
        "-i",
        "samples/",
        "-o",
        "samples/Runs/"
      ],
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
